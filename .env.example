# Server-only: where the LMS API lives. Used by the SSR/ISR data fetch and the
# /api/lead form proxy. NEVER prefix with NEXT_PUBLIC_ — backend URL stays
# private.
BACKEND_API_URL=http://localhost:8000

# HMAC secret shared with the backend (LANDING_REVALIDATE_SECRET). Must match
# the value in backend/.env.example.production. Leave EMPTY in dev to skip
# signature verification on the /api/revalidate webhook.
REVALIDATE_SECRET=

# Public site URL — used for canonical / OpenGraph URLs in <head>.
# Production uses https://ted.edu.az (set in .env.production, inlined at build time).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- SEO / analytics (all optional, PUBLIC, inlined at build; leave empty to disable) ---
# Search-engine ownership verification (from Search Console / Yandex Webmaster).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=
# Analytics: GA4 measurement id (G-XXXXXXX) and Yandex Metrica counter id (digits).
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_YM_ID=
# Exact centre coordinates for LocalBusiness geo in JSON-LD. Get them from Google
# Maps: right-click your location → the first number is latitude, second longitude.
NEXT_PUBLIC_GEO_LAT=
NEXT_PUBLIC_GEO_LNG=
